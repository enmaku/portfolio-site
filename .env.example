# TMDB for Movie Vote — set at least one (https://www.themoviedb.org/settings/api).
# Prefer Read Access Token (Bearer); otherwise v3 API key works.
#
# Local: copy to `.env` (gitignored), restart `quasar dev`.
# GitHub Actions: add secrets `TMDB_READ_ACCESS_TOKEN` and/or `TMDB_API_KEY`.
VITE_TMDB_READ_ACCESS_TOKEN=
VITE_TMDB_API_KEY=

# Firebase Realtime Database — Movie Vote, Game Timer, and Dungeon Runner replay archive (share VITE_FIREBASE_* below; one Firebase project; path-scoped RTDB rules in database.rules.json).
# Console: Project settings → Your apps → Web app config + Realtime Database URL.
# GitHub Actions: add the same names as repository secrets (see publish.yml).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
# Optional (standard Firebase web template)
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=

# Dungeon Runner — when unset or not 1/true/yes, NN runner picks adventurer at random (match RNG).
# Set to true on local dev to restore NN adventurer selection. Restart `quasar dev` after change.
# VITE_DUNGEON_RUNNER_NN_PICK_ADVENTURER=true

# Dungeon Runner TF.js model sync — sibling checkout of https://github.com/enmaku/dungeon-runner
# Used by scripts/sync-dungeon-runner-model.mjs and convert-dungeon-runner-h5.mjs to read
# models/<promoted-version>/policy.weights.h5 without cloning. Falls back to shallow git clone when unset.
DUNGEON_RUNNER_ROOT=
# Python with TensorFlow + tensorflowjs for H5→TF.js (dungeon-runner training venv is typical).
# PYTHON_BIN=/absolute/path/to/dungeon-runner/.venv/bin/python
